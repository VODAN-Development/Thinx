# Thinx Platform - Environment Configuration Template
# Copy this file to .env and update with your actual production values
# IMPORTANT: Never commit .env to version control!

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Environment: development, production, testing
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Secret key for session encryption (GENERATE A NEW ONE FOR PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# Session timeout in seconds (default: 1 hour)
SESSION_TIMEOUT=3600

# ============================================================================
# ALLEGROGRAPH DATABASE
# ============================================================================

# AllegroGraph server hostname (use 'allegrograph' for Docker, or IP/domain)
AGRAPH_HOST=allegrograph

# AllegroGraph port (default: 10035)
AGRAPH_PORT=10035

# Repository name in AllegroGraph
AGRAPH_REPOSITORY=humantrafficking

# AllegroGraph admin credentials (CHANGE THESE IN PRODUCTION!)
AGRAPH_SUPER_USER=admin
AGRAPH_SUPER_PASSWORD=change-this-secure-password

# ============================================================================
# FRONTEND & CORS
# ============================================================================

# Frontend URL (where users access the application)
VITE_API_URL=http://localhost:5000

# Allowed CORS origins (comma-separated, no spaces)
# In production, specify exact domains: https://your-domain.com
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5000
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# ============================================================================
# FILE UPLOADS
# ============================================================================

# Maximum upload file size in bytes (default: 50MB)
MAX_UPLOAD_SIZE=52428800

# Upload directory (inside container)
UPLOAD_FOLDER=/app/uploads

# Allowed file extensions (comma-separated)
ALLOWED_EXTENSIONS=xlsx,xls,json,csv

# ============================================================================
# AI SMART MAPPER (Optional - comment out to disable)
# ============================================================================

# Enable or disable AI features
OLLAMA_ENABLED=true

# Ollama server hostname (use 'ollama' for Docker)
OLLAMA_HOST=ollama

# Ollama server port
OLLAMA_PORT=11434

# Default AI model to use
OLLAMA_DEFAULT_MODEL=llama3.2

# AI request timeout in seconds
OLLAMA_TIMEOUT=120

# ============================================================================
# API SETTINGS
# ============================================================================

# API request timeout in seconds
API_TIMEOUT=30

# Maximum query results to return
MAX_QUERY_RESULTS=1000

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable request logging
LOG_REQUESTS=true

# ============================================================================
# SECURITY
# ============================================================================

# Enable user registration (set to false to disable self-registration)
ALLOW_REGISTRATION=true

# Minimum password length
MIN_PASSWORD_LENGTH=6

# Session cookie settings (set SESSION_COOKIE_SECURE=true with HTTPS)
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ============================================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================================

# 1. Generate strong SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# 2. Use secure passwords for AGRAPH_SUPER_PASSWORD
# 3. Set FLASK_ENV=production and FLASK_DEBUG=false
# 4. Configure CORS_ORIGINS with your actual domain
# 5. Enable HTTPS and set SESSION_COOKIE_SECURE=true
# 6. Keep this file secure - never commit to version control
# 7. Back up this file as part of your backup strategy
